# Copy this file to .env.local and fill in your Supabase project values
# (Dashboard -> Project Settings -> API).

# Public (safe to expose; Row Level Security protects the data):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (NEVER expose; used by the /dashboard API):
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Dashboard password. In production set it here (it overrides the
# admin.password value from wedding-config.json).
DASHBOARD_PASSWORD=change-this-password

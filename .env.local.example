# Copy this file to .env.local (and to your host's environment variables
# in production). Values come from Supabase Dashboard -> Project Settings -> API.

# --- public (safe to expose; Row Level Security protects the data) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- server only (NEVER exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Owner dashboard (/owner) password — required for the owner area.
OWNER_PASSWORD=choose-a-strong-owner-password

# Optional: dashboard password for the local template/demo wedding only
# (platform weddings store their own hashed password in the database).
DASHBOARD_PASSWORD=change-this-password

# Note: this project is Next.js, so client-side variables must use the
# NEXT_PUBLIC_ prefix (VITE_* names are a Vite convention and are not
# bundled by Next). The server also accepts VITE_SUPABASE_URL as an
# alias for the URL if you already have it set.
